          "latency": 0,
          "statusCode": 200,
          "label": "",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "filePath": "",
          "sendFileAsBody": false,
          "rules": [],
          "rulesOperator": "OR"
        }
      ],
      "enabled": true
    },
    {
      "uuid": "route-put-economy",
      "type": "http",
